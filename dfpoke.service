[Unit]
Description=DFpoke Card Tracker
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/DFpoke
Environment="SECRET_KEY=your_secret_key_here"
Environment="BAIDU_API_KEY=your_baidu_api_key_here"
Environment="BAIDU_SECRET_KEY=your_baidu_secret_key_here"
ExecStart=/home/ubuntu/DFpoke/venv/bin/gunicorn -w 1 --threads 4 --timeout 120 --max-requests 500 --max-requests-jitter 50 -b 0.0.0.0:8080 app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
